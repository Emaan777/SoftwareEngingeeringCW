doctype html
html
  head
    title Sport Buddy - Find Your Exercise Partner
    link(rel="stylesheet", href="/styles.css")
    style.
      body {
        font-family: 'Arial', sans-serif;
        line-height: 1.6;
        margin: 0;
        padding: 0;
        background: #f5f5f5;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem;
      }
      nav {
        background: #007bff;
        padding: 1rem;
        margin-bottom: 2rem;
      }
      nav a {
        color: white;
        text-decoration: none;
        margin-right: 1rem;
      }
      nav a:hover {
        text-decoration: underline;
      }
  body
    nav
      a(href="/") Home
      a(href="/listing") User Listings
      a(href="/profile") Profile
    .container
      block content
    
    script(src="/js/listing.js")
